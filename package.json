{
  "name": "mcp-remote",
  "version": "0.1.0",
  "description": "Remote proxy for Model Context Protocol servers with mTLS (mutual TLS) client certificate authentication support.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mtls",
    "mutual-tls",
    "proxy",
    "remote",
    "stdio"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "mcp-remote": "dist/proxy.js",
    "mcp-remote-client": "dist/client.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "start:proxy": "node dist/proxy.js",
    "start:client": "node dist/client.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "undici": "^6.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18"
  }
}
