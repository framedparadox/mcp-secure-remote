{
  "name": "mcp-secure-remote",
  "version": "0.0.2",
  "description": "Remote proxy for Model Context Protocol servers with mTLS (mutual TLS) client certificate authentication support.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mtls",
    "mutual-tls",
    "proxy",
    "remote",
    "stdio"
  ],
  "license": "MIT",
  "author": "framedparadox",
  "repository": {
    "type": "git",
    "url": "https://github.com/framedparadox/mcp-secure-remote.git"
  },
  "homepage": "https://github.com/framedparadox/mcp-secure-remote#readme",
  "bugs": {
    "url": "https://github.com/framedparadox/mcp-secure-remote/issues"
  },
  "type": "module",
  "bin": {
    "mcp-secure-remote": "dist/proxy.js",
    "mcp-secure-remote-client": "dist/client.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:unit": "vitest run test/unit --passWithNoTests",
    "test:integration": "vitest run test/integration --passWithNoTests",
    "start:proxy": "node dist/proxy.js",
    "start:client": "node dist/client.js",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "undici": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@vitest/coverage-v8": "^4.1.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
